# Choose any OpenAI-compatible vision provider by changing these three values.
# The same env keys work for OpenAI, Gemini, Groq, or another compatible endpoint.
TJM_VLM_BASE_URL=https://your-openai-compatible-base-url.example/v1
TJM_VLM_API_KEY=replace-with-your-api-key
TJM_VLM_MODEL=replace-with-your-vision-model
